<?xml version="1.0"?>
<model>
  <name>vbat_tailsitter</name>
  <version>0.1</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Onur Tuncer</name>
  </author>
  <description>
    V-BAT-like single-EDF jet-vane tailsitter (ADR-0011 draft).
    Inertia from out/mass_properties.yaml, geometry from
    out/fuselage.yaml and out/control_vanes.yaml at the 2.376 kg
    design point. Vane jet-wash aerodynamics are placeholders.
  </description>
</model>
