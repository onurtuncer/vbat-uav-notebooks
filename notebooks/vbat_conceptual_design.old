    "    (smd.tw_ceiling, 'Service ceiling', COLORS[2], '--'),\n",
    "    (smd.tw_vmax,    'Max speed',       COLORS[3], '-.'),\n",
    "    (smd.tw_takeoff, 'Take-off run',    COLORS[4], ':'),\n",
    "]\n",
    "for arr, label, c, ls in curves:\n",
