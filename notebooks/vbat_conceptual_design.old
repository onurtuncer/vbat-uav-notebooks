    "\n",
    "# Feasible region shading\n",
    "mask = WS <= smd.WS_stall\n",
    "ax.fill_between(WS[mask], 0, smd.tw_envelope[mask],\n",
    "                alpha=0.08, color='steelblue', label='Feasible region')\n",
    "\n",
    "# Design point\n",
    "ax.plot(smd.WS_design, smd.TW_design, 'r*', ms=14, zorder=10,\n",
    "        label=f'Design point ({smd.WS_design:.0f} N/m², T/W={smd.TW_design:.3f})')\n",
    "ax.annotate(f' Design\\n ({smd.WS_design:.0f}, {smd.TW_design:.3f})',\n",
    "            xy=(smd.WS_design, smd.TW_design),\n",
