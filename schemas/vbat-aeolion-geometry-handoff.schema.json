{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vbat-aeolion-geometry-handoff.schema.json",
  "title": "VBAT → Aeolion Parametric Geometry Handoff",
  "type": "object",
  "required": ["schema_version", "design_id", "units", "reference_frame", "planform", "airfoil_sections", "mesh_topology"],
  "properties": {

    "schema_version": {
      "type": "string",
      "enum": ["1.0.0", "1.1.0", "1.2.0", "1.3.0"],
      "description": "1.1.0 adds the optional control_surfaces[].surface binding field (1.0.0 documents bind by name); 1.2.0 adds the optional body block; 1.3.0 adds propulsion_bemt.n_blades"
    },
    "design_id": {
      "type": "string",
      "description": "Hash or UUID tying this parameter set to a specific notebook run for adjoint-loop traceability"
    },
    "units": {
      "type": "object",
      "required": ["length", "angle"],
      "properties": {
        "length": { "const": "m" },
        "angle":  { "const": "deg" }
      }
    },
    "reference_frame": {
      "type": "string",
      "enum": ["aetherion_body_frd"],
      "description": "Must match Aetherion/BEMT convention to avoid an undifferentiated transform seam"
    },

    "planform": {
      "type": "object",
      "required": ["span", "stations"],
      "properties": {
        "span": { "type": "number", "exclusiveMinimum": 0 },
        "stations": {
          "type": "array",
          "minItems": 2,
          "description": "Fixed-length array across the whole design space — count must never change between runs",
          "items": {
            "type": "object",
            "required": ["eta", "chord", "twist", "sweep_qc", "dihedral"],
            "properties": {
              "eta":        { "type": "number", "minimum": 0, "maximum": 1 },
              "chord":      { "type": "number", "exclusiveMinimum": 0 },
              "twist":      { "type": "number" },
              "sweep_qc":   { "type": "number" },
              "dihedral":   { "type": "number" }
            }
          }
        }
      }
    },

    "airfoil_sections": {
      "type": "array",
      "minItems": 2,
      "description": "Must align 1:1 with planform.stations by eta — same count, fixed",
      "items": {
        "type": "object",
        "required": ["eta", "parameterization", "coefficients_upper", "coefficients_lower"],
        "properties": {
          "eta": { "type": "number", "minimum": 0, "maximum": 1 },
          "parameterization": { "const": "CST" },
          "coefficients_upper": {
            "type": "array",
            "minItems": 4,
            "maxItems": 8,
            "items": { "type": "number" }
          },
          "coefficients_lower": {
            "type": "array",
            "minItems": 4,
            "maxItems": 8,
            "items": { "type": "number" }
          }
        }
      }
    },

    "control_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "eta_start", "eta_end", "chord_fraction", "hinge_axis"],
        "properties": {
          "name": { "type": "string", "enum": ["vane", "aileron", "rudder"] },
          "surface": {
            "type": "string",
            "enum": ["wing", "duct_jet"],
            "description": "Lattice binding (1.1.0): the geometric surface this entry belongs to. wing: eta is the semispan fraction of the planform. duct_jet: an all-moving plate in the duct jet, eta is the duct-exit radius fraction -- never bound to a lifting-surface lattice. When absent (1.0.0), bind by name: aileron/rudder -> wing, vane -> duct_jet."
          },
          "eta_start": { "type": "number" },
          "eta_end":   { "type": "number" },
          "chord_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
          "hinge_axis": {
            "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3
          }
        }
      }
    },

    "body": {
      "type": "object",
      "description": "Optional (1.2.0): the fuselage as a body of revolution in the declared reference frame -- x = 0 at the nose tip, negative aft, stations span [-length, 0], nose -> tail. Fixed station count across the design space (remeshing is an outer-loop event). radius is 0 at the nose tip; the aft-most station carries the tail-base (hub) radius. Not bound to any lifting lattice -- intended for slender-body/Munk trim corrections and duct-jet context.",
      "required": ["length", "stations"],
      "properties": {
        "length": { "type": "number", "exclusiveMinimum": 0 },
        "stations": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["x", "radius"],
            "properties": {
              "x":      { "type": "number", "maximum": 0 },
              "radius": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },

    "propulsion_bemt": {
      "type": "object",
      "properties": {
        "disk_radius":      { "type": "number", "exclusiveMinimum": 0 },
        "reference_rpm":    { "type": "number" },
        "n_blades": {
          "type": "integer",
          "minimum": 1,
          "description": "Blade count (1.3.0). Required for solidity/thrust in BEMT; blade_stations alone describes one blade's chord/twist law, not the rotor."
        },
        "blade_stations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["r_over_R", "chord", "twist"],
            "properties": {
              "r_over_R": { "type": "number", "minimum": 0, "maximum": 1 },
              "chord":    { "type": "number" },
              "twist":    { "type": "number" }
            }
          }
        }
      }
    },

    "mesh_topology": {
      "type": "object",
      "description": "Static discretization directives — NOT design variables, must stay constant across the entire optimization to preserve gradient continuity",
      "required": ["chordwise_panels", "spanwise_panels_per_section"],
      "properties": {
        "chordwise_panels": { "type": "integer", "minimum": 4 },
        "spanwise_panels_per_section": { "type": "integer", "minimum": 1 },
        "wake_model": { "type": "string", "enum": ["frozen", "relaxed"] }
      }
    }
  },

  "additionalProperties": false
}
